# PostgreSQL connection string (Prisma Postgres, Neon, Supabase, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
SESSION_SECRET="replace-with-32-byte-random-secret"

# Odoo ecommerce integration. Keep these server-side only.
ODOO_URL="https://jhonny-surf.odoo.com"
ODOO_DB="jhonny-surf-master-26611951"
ODOO_USERNAME="jhonnysurfstore@gmail.com"
ODOO_API_KEY="replace-with-odoo-api-key"
ODOO_LIVE_CATALOG="false"
ODOO_AUTO_CONFIRM_SALE_ORDER="true"
ODOO_CREATE_INVOICE_AFTER_PAYMENT="true"
ODOO_AUTO_VALIDATE_DELIVERY="false"

# Ifthenpay covers MB WAY and Multibanco when these account keys are enabled.
IFTHENPAY_MBWAY_KEY="replace-with-ifthenpay-mbway-key"
IFTHENPAY_MB_KEY="replace-with-ifthenpay-multibanco-key-or-dynamic-key"
IFTHENPAY_BACKOFFICE_KEY="replace-with-ifthenpay-backoffice-key-if-needed"
IFTHENPAY_CALLBACK_SECRET="replace-with-ifthenpay-callback-secret-or-anti-phishing-key"
IFTHENPAY_CALLBACK_URL="https://www.jhonnysurfstore.com/api/payments/ifthenpay/callback"

# Optional providers if Jhonny enables them separately.
PAYPAL_CLIENT_ID="replace-with-paypal-client-id"
PAYPAL_CLIENT_SECRET="replace-with-paypal-client-secret"
PAYPAL_WEBHOOK_ID="replace-with-paypal-webhook-id"
PAYPAL_ENVIRONMENT="sandbox"
KLARNA_USERNAME="replace-with-klarna-username"
KLARNA_PASSWORD="replace-with-klarna-password"

# Transactional email provider. For Gmail, use a Google App Password, not the normal Gmail password.
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="replace-with-gmail-address"
SMTP_PASSWORD="replace-with-google-app-password"
EMAIL_FROM="Jhonny Surf Store <replace-with-gmail-address>"
JHONNY_ORDER_EMAIL="jhonnysurfstore@gmail.com"

# Optional Resend fallback if we decide to use a transactional email provider instead of Gmail.
RESEND_API_KEY="replace-with-resend-api-key"

# Instagram Graph API-ready media integration.
# For each handle, add INSTAGRAM_<HANDLE>_ACCOUNT_ID where non-alphanumeric chars become underscores.
INSTAGRAM_GRAPH_ACCESS_TOKEN="replace-with-instagram-graph-token"
# Connected Instagram business/creator account used to discover public business/creator profile photos.
INSTAGRAM_GRAPH_SOURCE_ACCOUNT_ID="replace-with-connected-instagram-account-id"
INSTAGRAM_DUDES_SURFCAFE_ACCOUNT_ID="replace-with-dudes-instagram-account-id"
# Optional static fallback JSON when Graph API is not connected:
# INSTAGRAM_DUDES_SURFCAFE_MEDIA_JSON='[{"id":"1","mediaUrl":"https://...","permalink":"https://www.instagram.com/p/..."}]'
# Optional direct athlete avatar URLs when you export/copy profile photos:
# INSTAGRAM_MADALENAMGUERREIRO_AVATAR_URL="https://..."
# INSTAGRAM__MELENDEZZZ_AVATAR_URL="https://..."
